{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/App.tsx", "src/features/**/*.tsx", "src/pages/**/*.tsx"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/hooks/useSettings.ts",
    "src/hooks/useHealthLog.ts",
    "src/lib/metrics/**",
    "src/features/auth/store.ts"
  ],
  "ignoreExportsUsedInFile": true
}
