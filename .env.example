# Database Configuration - REQUIRED
POSTGRES_USER=life_as_code_user
POSTGRES_PASSWORD=
POSTGRES_DB=life_as_code
DATABASE_URL=

# Application Security Keys - REQUIRED (Generate with scripts below)
SECRET_KEY=
FERNET_KEY=

# Rate Limiting Backend - RECOMMENDED (for production with multiple workers)
# Use Redis for production to share rate limit state across workers
# If not set, defaults to redis://localhost:6379/0 with in-memory fallback
REDIS_URL=redis://redis:6379/0

# Default Admin User - REQUIRED
# Password must be at least 12 characters with uppercase, lowercase, digit, and special character
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=

# Service Credentials - OPTIONAL (for data syncing)
GARMIN_EMAIL=
GARMIN_PASSWORD=
HEVY_API_KEY=

# Whoop OAuth Credentials - OPTIONAL (Register app at developer.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Scheduler Configuration - OPTIONAL
SYNC_INTERVAL_HOURS=4
SYNC_DAYS=7

# Telegram Bot - OPTIONAL (for health bot notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# Claude API - OPTIONAL (for AI health insights)
ANTHROPIC_API_KEY=

# Logging Configuration - OPTIONAL
LOG_LEVEL=INFO
LOG_FORMAT=json

# === SETUP INSTRUCTIONS ===
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Generate secure values:
#    SECRET_KEY=$(python -c 'import secrets; print(secrets.token_hex(32))')
#    FERNET_KEY=$(python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())')
#    POSTGRES_PASSWORD=$(python -c 'import secrets; print(secrets.token_urlsafe(32))')
#    ADMIN_PASSWORD=$(python -c 'import secrets; print(secrets.token_urlsafe(24))')
#
# 3. Update .env with generated values:
#    sed -i '' "s/^SECRET_KEY=.*/SECRET_KEY=$SECRET_KEY/" .env
#    sed -i '' "s/^FERNET_KEY=.*/FERNET_KEY=$FERNET_KEY/" .env
#    sed -i '' "s/^POSTGRES_PASSWORD=.*/POSTGRES_PASSWORD=$POSTGRES_PASSWORD/" .env
#    sed -i '' "s/^ADMIN_PASSWORD=.*/ADMIN_PASSWORD=$ADMIN_PASSWORD/" .env
#
# 4. Set database connection URL:
#    DATABASE_URL=postgresql+psycopg2://life_as_code_user:$POSTGRES_PASSWORD@db:5432/life_as_code
#
# 5. (Optional) Add service credentials for data syncing:
#    GARMIN_EMAIL=your-garmin-email@example.com
#    GARMIN_PASSWORD=your-garmin-password
#    HEVY_API_KEY=your-hevy-api-key
#
# 6. Start the application:
#    docker-compose up --build -d
#
# NOTE: Credentials are now managed through environment variables only.
#       The web UI no longer allows editing credentials for security reasons.
