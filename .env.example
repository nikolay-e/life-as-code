# Database Configuration - REQUIRED
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=

# Application Security Keys - REQUIRED (Generate with scripts below)
SECRET_KEY=
FERNET_KEY=

# Optional API Credentials (can be set later via web UI)
EMAIL=
PASSWORD=
HEVY_API_KEY=

# === SETUP INSTRUCTIONS ===
