# PostgreSQL Database credentials
POSTGRES_USER=life_as_code_user
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=life_as_code_db

# The web app uses this to connect to the database
DATABASE_URL=postgresql+psycopg2://life_as_code_user:change_this_to_a_strong_password@db:5432/life_as_code_db

# Security & Authentication
SECRET_KEY=your-very-secret-app-key-for-sessions
FERNET_KEY=your-fernet-key-for-credential-encryption

# Generate FERNET_KEY with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Flask Debug Mode (set to True for development only)
FLASK_DEBUG=False
