# Database connection (read-only access to lifeascode_production)
LAC_DATABASE_URL=postgresql://lifeascode_production:<password>@postgres.local:5432/lifeascode_production

# Per-user device onset epochs (ISO YYYY-MM-DD).
# Set to the date the user started wearing each device, or leave empty if not used.
# These define epoch dummies in residualization and the date-start filter for hypothesis tests.
LAC_GOOGLE_FIT_EPOCH=
LAC_APPLE_HEALTH_EPOCH=
LAC_HEVY_EPOCH=
LAC_GARMIN_EPOCH=
LAC_WHOOP_EPOCH=
LAC_EIGHT_SLEEP_EPOCH=
