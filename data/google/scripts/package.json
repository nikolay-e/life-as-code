{
  "name": "google-fit-import",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "import": "npx tsx import-google-fit.ts",
    "import:all": "npx tsx import-google-fit.ts",
    "import:csv": "npx tsx import-google-fit.ts --skip-sleep --skip-body --skip-sessions",
    "import:sleep": "npx tsx import-google-fit.ts --skip-csv --skip-body --skip-sessions",
    "import:body": "npx tsx import-google-fit.ts --skip-csv --skip-sleep --skip-sessions",
    "import:sessions": "npx tsx import-google-fit.ts --skip-csv --skip-sleep --skip-body",
    "test": "npx tsx import-google-fit.ts --dry-run",
    "test:sleep": "npx tsx import-google-fit.ts --dry-run --skip-csv --skip-body --skip-sessions"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
